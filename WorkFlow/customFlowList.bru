meta {
  name: customFlowList
  type: http
  seq: 1
}

post {
  url: {{apiURL}}/Mobileapi/customFlowList
  body: json
  auth: inherit
}

body:json {
  {"user_id":"{{user_id}}","filters_data":{"requested_for":1,"request_process":"4","initiated_created_from":"","initiated_created_to":"","approval_status":"","workflow_status":""},"token":"{{token}}"}
}

script:pre-request {
  await bru.sendRequest({
      url: bru.getEnvVar("apiURL") + "/Mobileapi/auth",
      method: 'POST',
      headers: {
          'Content-Type': 'application/json'
      },
      data: JSON.stringify({
          "username": "600",
          "password": "Dbox@1"
      })
  }, async function(err, res) {
      if (err) {
          console.log("Login API failed:", err);
      } else {
          let json = res.data;
  
          // Store values in environment
          bru.setEnvVar("token", json.token);
          bru.setEnvVar("tenant_id", json.tenant_id);
          bru.setEnvVar("user_id", json.user_id);
      }
  });
  
}

script:post-response {
  test("Checking for status code 200", function () {
      expect(res.getStatus()).to.equal(200);
  });
}

settings {
  encodeUrl: true
}
