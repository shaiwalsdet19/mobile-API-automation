meta {
  name: CheckPositionsAllowed
  type: http
  seq: 14
}

post {
  url: {{apiURL}}/RecruitmentMobileapi/CheckPositionsAllowed
  body: json
  auth: inherit
}

body:json {
  {"designation_id":"a6424773077b2f","project_id":"","rest_location":"","functional_area":"","token":"{{token}}"}
}

script:pre-request {
  await bru.sendRequest({
      url: bru.getEnvVar("apiURL") + "/Mobileapi/auth",
      method: 'POST',
      headers: {
          'Content-Type': 'application/json'
      },
      data: JSON.stringify({
          "username": "501",
          "password": "Mobile@12"
      })
  }, async function(err, res) {
      if (err) {
          console.log("Login API failed:", err);
      } else {
          let json = res.data;
  
          // Store values in environment
          bru.setEnvVar("token", json.token);
          bru.setEnvVar("tenant_id", json.tenant_id);
          bru.setEnvVar("user_id", json.user_id);
      }
  });
  
}

script:post-response {
  test("Checking for status code 200", function () {
      expect(res.getStatus()).to.equal(200);
  });
  test("Schema is valid", function () {
      const schema = {
          "type": "object",
          "required": ["status", "is_allowed", "message"],
          "properties": {
              "status": {
                  "type": "integer"
              },
              "is_allowed": {
                  "type": "boolean"
              },
              "message": {
                  "type": "string"
              }
          },
          "additionalProperties": false
      };
  
  //     pm.response.to.have.jsonSchema(schema);
  });
  
}

settings {
  encodeUrl: true
}
