                          }
                      },
                      "initiator_form": { "type": "array" },
                      "approval_flow": { "type": "array" },
                      "initiator_form_new": { "type": "array" },
                      "is_req_creation_completed": { "type": "boolean" },
                      "is_editable": { "type": "boolean" },
                      "is_rejected": { "type": "boolean" },
                      "rejected_reason": { "type": "string" },
                      "job_name": { "type": "string" },
                      "status": { "type": "integer" },
                      "settings": { "type": "object" },
                      "task_id": { "type": "string" },
                      "custom_flow_id": { "type": "string" },
                      "approval_flow_set_id": { "type": "string" },
                      "category": { "type": "string" },
                      "show_act_button": { "type": "boolean" },
                      "is_job_details_edit_allowed": { "type": "boolean" },
                      "is_position_edit_allowed": { "type": "boolean" },
                      "is_others_details_edit_allowed": { "type": "boolean" },
                      "type_of_position": { "type": "string" },
                      "is_old_form": { "type": "boolean" }
                  }
              }
          },
          "additionalProperties": false
      };
  
  //     pm.response.to.have.jsonSchema(schema);
  });
  
}

settings {
  encodeUrl: true
