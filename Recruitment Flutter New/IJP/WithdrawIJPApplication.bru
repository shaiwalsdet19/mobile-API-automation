meta {
  name: WithdrawIJPApplication
  type: http
  seq: 8
}

post {
  url: {{apiURL}}/RecruitmentMobileapi/WithdrawIJPApplication
  body: json
  auth: inherit
}

body:json {
  {"id":"{{candidate_id}}","withdraw_reason":"tesy","token":"{{token}}"}
