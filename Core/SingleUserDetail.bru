meta {
  name: SingleUserDetail
  type: http
  seq: 1
}

post {
  url: {{apiURL}}/Mobileapi/SingleUserDetail?user=413069&token={{token}}
  body: json
  auth: inherit
}

params:query {
  user: 413069
  token: {{token}}
}

body:json {
  {"user":"413069","token":"{{token}}"}
}

script:pre-request {
  await bru.sendRequest({
      url: bru.getEnvVar("apiURL") + "/Mobileapi/auth",
      method: 'POST',
      headers: {
          'Content-Type': 'application/json'
      },
      data: JSON.stringify({
          "username": "600",
          "password": "Dbox@1"
      })
  }, async function(err, res) {
      if (err) {
          console.log("Login API failed:", err);
      } else {
          let json = res.data;
  
          // Store values in environment
          bru.setEnvVar("token", json.token);
          bru.setEnvVar("tenant_id", json.tenant_id);
          bru.setEnvVar("user_id", json.user_id);
      }
  });
  
}

script:post-response {
  test("Checking for status code 200", function () {
      expect(res.getStatus()).to.equal(200);
  });
}

settings {
  encodeUrl: true
}
