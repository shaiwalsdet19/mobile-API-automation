meta {
  name: GetShiftSwapShiftsNames
  type: http
  seq: 13
}

post {
  url: {{apiURL}}/attendance/attendanceMobileApi/GetShiftSwapShiftsNames
  body: json
  auth: inherit
}

body:json {
  {"swap_user_id":"a6375d08226194","shift_swap_date":"27.06.2025","request_type":9,"token":"{{token}}"}
  
}

script:pre-request {
  await bru.sendRequest({
      url: bru.getEnvVar("apiURL") + "/Mobileapi/auth",
      method: 'POST',
      headers: {
          'Content-Type': 'application/json'
      },
      data: JSON.stringify({
          "username": "501",
          "password": "Mobile@12"
      })
  }, async function(err, res) {
      if (err) {
          console.log("Login API failed:", err);
      } else {
          let json = res.data;
  
          // Store values in environment
          bru.setEnvVar("token", json.token);
          bru.setEnvVar("tenant_id", json.tenant_id);
          bru.setEnvVar("user_id", json.user_id);
      }
  });
  
}

script:post-response {
  test("Status code is 200", function () {
      expect(res.getStatus()).to.equal(200);
  });
}

settings {
  encodeUrl: true
}
